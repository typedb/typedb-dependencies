+fn find_bazel_protoc() -> Option<String> {
+    let out_dir = env::var("OUT_DIR").ok()?;
+    let execroot = &out_dir[..out_dir.find("/bazel-out/")?];
+    // Scan bazel-out for protoc binary under the protobuf+ external repo
+    for entry in std::fs::read_dir(format!("{}/bazel-out", execroot)).ok()? {
+        let config_dir = entry.ok()?.path();
+        let candidate = config_dir.join("bin/external/protobuf+/protoc");
+        if candidate.is_file() {
+            if let Ok(s) = check_protoc_version(candidate.to_str()?) {
+                return Some(s);
+            }
+        }
+    }
+    None
+}
